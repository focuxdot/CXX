{
  "name": "cxx",
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "description": "Remote-control your local ChatGPT / Claude Code from your phone. Install alongside existing CLIs — no patched agent required.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "daemon": "node daemon/src/main.mjs start",
    "pair": "node daemon/src/main.mjs pair",
    "notify": "node daemon/src/main.mjs notify",
    "relay": "node relay/node/server.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:rtc": "node scripts/smoke-rtc.mjs",
    "smoke:pty": "node scripts/smoke-pty.mjs",
    "smoke:terminal": "node scripts/smoke-terminal.mjs",
    "smoke:terminal:e2e": "node scripts/smoke-terminal-e2e.mjs",
    "build:pty-host": "node scripts/build-pty-host.mjs",
    "test": "node --test",
    "check:schema": "node scripts/check-schema.mjs",
    "check:schema:update": "node scripts/check-schema.mjs --update",
    "build:sea": "node scripts/build-sea.mjs",
    "build:app": "node scripts/build-app.mjs",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts/build-win.ps1",
    "build:win:installer": "powershell -ExecutionPolicy Bypass -File scripts/build-win-installer.ps1",
    "build:linux": "node scripts/build-sea.mjs"
  }
}
