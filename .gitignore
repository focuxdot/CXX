node_modules/
.wrangler/
dist/
release-assets/
*.log
.DS_Store

# Internal planning stays machine-local. The official relay overlay is the narrow exception:
# its source/config declarations are versioned for reproducible deploys; secrets stay in Wrangler.
internal/*
!internal/RELAY-QUOTA-HARDENING.md
!internal/relay-worker/
internal/relay-worker/*
!internal/relay-worker/README.md
!internal/relay-worker/wrangler.official.toml
!internal/relay-worker/src/
!internal/relay-worker/src/**
!internal/relay-worker/test/
!internal/relay-worker/test/**
internal/relay-worker/.dev.vars*
internal/relay-worker/.env*
internal/relay-worker/.wrangler/
docs/

# Keep obsolete machine-local Worker entrypoint/config names out of the public self-hosting tree.
relay/worker/src/*.local.mjs
relay/worker/wrangler*.local.toml

# maintainer-only git account-safety tooling — machine-local, references a personal
# SSH identity; kept on disk so it stays active locally but never published
.githooks/
scripts/git-push-maintainer.mjs

# local daemon state (should never be committed)
.cxx/
daemon.json
# build artifacts
*.blob
shell/macos/build/
shell/macos/DerivedData/
shell/macos/.build/
